# branchShredder - AI API Keys
# Copy this file to .env and fill in any keys for providers you want to use.
# Lines beginning with # are ignored.  Values may optionally be quoted.
# Only keys that are present (non-empty) will appear in the AI model dropdown.
#

#####################
## Cloud providers ####
#########################

# OpenAI  (GPT-4o, GPT-4o Mini, GPT-4 Turbo, GPT-3.5 Turbo)
# https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic  (Claude 3.5 Sonnet / Haiku, Claude 3 Opus)
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Groq  (hosted Llama 3.3 70B, Llama 3.1 8B, Mixtral 8×7B, Gemma 2 - very fast, free tier available)
# https://console.groq.com/keys
GROQ_API_KEY=

# Google Gemini  (Gemini 2.0 Flash, 1.5 Pro, 1.5 Flash)
# https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

########################
## Local Llama models ####
############################

# No key needed.  Use "↓ Download a Llama model…" in the AI Prompt Bar to
# fetch a GGUF model from Hugging Face Hub, .  Requires:
#   pip install huggingface_hub llama-cpp-python
